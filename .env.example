# ═══════════════════════════════════════════════════════════════════════════════
# Resume Score — Root Environment Variables
# Copy to .env.local for local development
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_score
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/resume_score_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=resume-score
KAFKA_GROUP_ID_PREFIX=resume-score

# ─── AI Provider Keys ─────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEFAULT_LLM_PROVIDER=gemini

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Vector Database ──────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
# PINECONE_API_KEY=
# PINECONE_INDEX=resume-score

# ─── Service URLs (for local dev — API Gateway routes to these) ────────────────
AUTH_SERVICE_URL=http://localhost:8002
USER_SERVICE_URL=http://localhost:3003
RESUME_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:8001
NOTIFICATION_SERVICE_URL=http://localhost:3004
SEARCH_SERVICE_URL=http://localhost:3005

# ─── API Gateway ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BUCKET=resume-score-uploads
# For local dev use supabase storage or minio:
STORAGE_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ─── GCP (for production) ─────────────────────────────────────────────────────
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=resume-score
