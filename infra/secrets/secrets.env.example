# ============================================================
# ResumeLM Secrets Template
#
# Copy this file to secrets.env and fill in real values.
# NEVER commit secrets.env to source control.
#
# In production, prefer injecting secrets via:
#   - Kubernetes Secrets (base64-encoded, referenced as envFrom)
#   - AWS Secrets Manager / Parameter Store
#   - HashiCorp Vault
#   - Docker Swarm secrets
# ============================================================

# ---- Supabase -------------------------------------------------------
# The service-role key bypasses RLS. Prefer per-service credentials
# (see infrastructure/migrations/003_add_rls_policies.sql).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ---- AI Providers ---------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ---- Stripe ---------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ---- Redis ----------------------------------------------------------
REDIS_PASSWORD=change_me_in_production
RABBITMQ_USER=resumelm
RABBITMQ_PASSWORD=change_me_in_production

# ---- Observability --------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# ---- Service-to-service auth (mTLS / JWT) ---------------------------
# A shared HS256 signing key used by services to sign and verify
# inter-service JWT tokens. Must be at least 32 characters.
SERVICE_AUTH_SECRET=change_me_min_32_chars_long_secret_here

# ---- Rate limiting (Upstash Redis) ----------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
