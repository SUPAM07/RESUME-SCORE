{
  "name": "resume-score",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/resume-service",
    "services/notification-service",
    "services/api-gateway",
    "services/user-service",
    "services/search-service",
    "services/shared"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@resume-score/web",
    "dev:services": "turbo dev --filter=./services/*",
    "build": "turbo build",
    "build:web": "turbo build --filter=@resume-score/web",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "infra:dev": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "generate-events": "tsx scripts/generate-event-types.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
